# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=replace-with-your-gemini-api-key

# APP_URL: The URL where the web app/backend is hosted.
APP_URL=http://localhost:3000

# VITE_API_BASE_URL: Required for production Android builds.
# Example: https://api.your-healthmate-domain.com
VITE_API_BASE_URL=

# MongoDB URI connection string for storing HealthMate profile & BMI history
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/healthmate

# NodeMailer SMTP Credentials (Required for production OTP email delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=healthmateofficialapp@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_SENDER_NAME=HealthMate Support
